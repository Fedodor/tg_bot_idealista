# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL async DSN (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://radar:radar@localhost:5432/radar

# ─── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── Logging ─────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ─── AI / Ollama ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ─── Postgres Docker credentials (used by docker-compose) ────────────────────
POSTGRES_USER=radar
POSTGRES_PASSWORD=radar
POSTGRES_DB=radar

# ─── Redis (for future async workers) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
